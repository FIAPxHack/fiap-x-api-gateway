{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}"
  },
  "Services": {
    "UserService": {
      "Url": "${USER_SERVICE_URL}"
    },
    "AuthService": {
      "Url": "${AUTH_SERVICE_URL}"
    },
    "VideoProcessingService": {
      "Url": "${VIDEO_PROCESSING_SERVICE_URL}"
    },
    "NotificationService": {
      "Url": "${NOTIFICATION_SERVICE_URL}"
    }
  }
}